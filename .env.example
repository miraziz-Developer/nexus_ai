# Chutes API Configuration
# Get your key at https://chutes.ai → API Keys (prefix: cpk_)
CHUTES_API_KEY=cpk_your_api_key_here
CHUTES_INFERENCE_URL=https://llm.chutes.ai/v1
CHUTES_MANAGEMENT_URL=https://api.chutes.ai

# OAuth (Sign In with Chutes) — register app at https://chutes.ai
CHUTES_OAUTH_CLIENT_ID=your_oauth_client_id
CHUTES_OAUTH_CLIENT_SECRET=your_oauth_client_secret
CHUTES_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Application
APP_NAME=Aether Nexus AI
APP_ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# Agent models on Chutes decentralized network
ARCHITECT_MODEL=Qwen/Qwen3-32B-TEE
VALIDATOR_MODEL=Qwen/Qwen3-32B-TEE
AUDITOR_MODEL=Qwen/Qwen3-32B-TEE

# Set to false for real on-chain Chutes inference (required for judging)
MOCK_CHUTES_WHEN_NO_KEY=false
CHUTES_FALLBACK_ON_ERROR=true
